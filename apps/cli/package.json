{
  "name": "@grimoire-ai/cli",
  "version": "0.3.2",
  "description": "Local-first, AI-native requirements management CLI",
  "homepage": "https://grimoireai.quest",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mikevalstar/grimoire.git",
    "directory": "apps/cli"
  },
  "bin": {
    "grimoire": "./dist/index.mjs"
  },
  "files": [
    "dist",
    "website"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack && mkdir -p website && cp -r ../website/dist website/dist",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check"
  },
  "dependencies": {
    "@grimoire-ai/core": "workspace:*",
    "@grimoire-ai/server": "workspace:*",
    "commander": "^14.0.3",
    "open": "catalog:",
    "picocolors": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  }
}
